<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.arr.calendar"
       name="arr Calendar"
       version="1.0.0"
       provider-name="User">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">arr Calendar</summary>
    <description lang="en_GB">Browse upcoming movies from Radarr and upcoming TV episodes from Sonarr directly inside Kodi. Configure your API keys and URLs in the addon settings.</description>
    <platform>all</platform>
    <license>GPL-2.0-or-later</license>
    <forum/>
    <website/>
    <source/>
    <news>
      v1.0.0 - Initial release
    </news>
  </extension>

</addon>
